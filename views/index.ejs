<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>修行者名簿</title></head>
<body>
  <h1>修行者名簿</h1>
  <ul>
    <% users.forEach(user => { %>
      <li><%= user.name %> (ID: <%= user.id %>)</li>
    <% }) %>
  </ul>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="新しい修行者の名前" required>
    <button type="submit">登録！</button>
  </form>
</body>
</html>
